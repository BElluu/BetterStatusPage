# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Random string, min 32 chars — used to sign JWT tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# 64-char hex string (32 bytes) — used to encrypt vault secrets with AES-256-GCM
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if this changes, all stored vault secrets become unreadable
VAULT_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# ── First-run setup ───────────────────────────────────────────────────────────
# Used only during the initial setup wizard to create the first admin account.
# Can be left empty after setup is complete.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file
DATABASE_PATH=./data/db.sqlite
# Path where uploaded files (logos, favicons) are stored
UPLOAD_DIR=./data/uploads

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave unset to allow all in dev,
# or to let Nginx handle CORS in production.
# ALLOWED_ORIGINS=https://status.example.com,https://admin.example.com
