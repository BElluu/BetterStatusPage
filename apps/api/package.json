{
  "name": "@bsp/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "backup": "node dist/cli/backup.js",
    "backup:verify": "node dist/cli/backup.js --verify",
    "restore": "node dist/cli/restore.js"
  },
  "dependencies": {
    "@bsp/shared": "*",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.40.1",
    "fastify": "^5.3.2",
    "mssql": "^11.0.1",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "ping": "^0.4.4",
    "undici": "^7.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/ping": "^0.4.4",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
