{
  "name": "@bsp/api",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "backup": "node dist/cli/backup.js",
    "backup:verify": "node dist/cli/backup.js --verify",
    "restore": "node dist/cli/restore.js",
    "2fa:reset": "node dist/cli/resetTwoFactor.js"
  },
  "dependencies": {
    "@bsp/shared": "*",
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.2",
    "mssql": "^11.0.1",
    "nanoid": "^5.1.5",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "ping": "^0.4.4",
    "qrcode": "^1.5.4",
    "undici": "^7.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/ping": "^0.4.4",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3"
  }
}
