{
  "name": "better-status-page",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/admin\" \"npm run dev -w apps/status\"",
    "start": "npm run start -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test:api && npm run test:frontend",
    "test:api": "tsx --test apps/api/test/*.test.ts",
    "test:frontend": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "setup": "npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/smtp-server": "^3.5.13",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.1.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "smtp-server": "^3.19.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  }
}
